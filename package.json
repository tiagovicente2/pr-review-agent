{
	"name": "pr-review-agent",
	"version": "0.1.0",
	"private": true,
	"description": "Local-first Electrobun desktop app for AI-assisted GitHub pull request review drafts.",
	"type": "module",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build": "vite build",
		"build:app": "vite build && electrobun build",
		"build:canary": "vite build && electrobun build --env=canary",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check ."
	},
	"dependencies": {
		"electrobun": "1.18.1",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/bun": "latest",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/three": "^0.184.0",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
